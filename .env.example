# Copy to .env and edit as needed

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=churn-prediction
MLFLOW_MODEL_NAME=ChurnModel

# Logistic Regression hyperparams
LR_C=1.0
LR_MAX_ITER=1000
PROMOTE_THRESHOLD=0.005

# Data path (defaults to Dataset/ folder relative to this file)
# DATA_PATH=/absolute/path/to/data.csv

# Server
HOST=0.0.0.0
PORT=8000
